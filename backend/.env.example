# Database (docker compose up -d)
DB_CONNECTION_STRING=mongodb://localhost:27017/openai-func?directConnection=true

# Authentication
JWT_SECRET=your-jwt-secret-here

# OpenAI
OPENAI_API_KEY=sk-...

# Blockchain RPC (Base Sepolia)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_INFURA_KEY

# Basescan Verification (free key from basescan.org/myapikey)
BASESCAN_API_KEY=your-basescan-api-key

# Optional
# PORT=3001
# CORS_ORIGIN=http://localhost:3000
# TEST_MNEMONIC=twelve word mnemonic for debug scripts (scripts/test-wallet.js)
